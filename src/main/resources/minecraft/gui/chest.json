{
  "id": "minecraft:chest",
  "groups": [
    {
      "id": "container",
      "type": "grid",
      "inventorySource": "container",
      "cols": 9,
      "spacing": 4,
      "anchor": "center",
      "centerCombined": true
    },
    {
      "id": "player_pockets",
      "type": "grid",
      "inventorySource": "player",
      "startIndex": 9,
      "slotsCount": 8,
      "cols": 8,
      "spacing": 4,
      "relativeTo": "container",
      "relativeAlign": "bottom",
      "relativeAlignX": "center",
      "fixedOffsetY": "1s"
    },
    {
      "id": "player_hotbar",
      "type": "grid",
      "inventorySource": "player",
      "startIndex": 0,
      "slotsCount": 9,
      "cols": 9,
      "spacing": 4,
      "relativeTo": "player_pockets",
      "relativeAlign": "bottom",
      "relativeAlignX": "center",
      "fixedOffsetY": "1s"
    }
  ],
  "background": {
    "type": "solid",
    "color": [0.1, 0.1, 0.1, 0.8],
    "padding": 12,
    "includeGroups": ["container", "player_pockets", "player_hotbar"]
  }
}
