{
  "id": "minecraft:player_inventory",
  "title": "container.inventory",
  "groups": [
    {
      "id": "equipment",
      "type": "vertical",
      "relativeTo": "pockets",
      "relativeAlign": "left",
      "relativeAlignY": "bottom",
      "fixedOffsetX": -10,
      "y": "-5%",
      "rows": 4,
      "spacing": 4,
      "placeholders": {
        "0": "empty_armor_slot_helmet",
        "1": "empty_armor_slot_chestplate",
        "2": "empty_armor_slot_leggings",
        "3": "empty_armor_slot_boots",
        "5": "bundle"
      }
    },
    {
      "id": "offhand",
      "type": "grid",
      "relativeTo": "pockets",
      "relativeAlign": "left",
      "relativeAlignY": "top",
      "fixedOffsetX": -10,
      "y": "-4%",
      "cols": 1,
      "rows": 1,
      "placeholders": {
        "0": "empty_armor_slot_shield"
      }
    },
    {
      "id": "pockets",
      "type": "grid",
      "relativeTo": "hotbar",
      "relativeAlignX": "center",
      "alignY": "bottom",
      "fixedOffsetX": 20,
      "y": "-5%",
      "fixedOffsetY": 60,
      "cols": 4,
      "rows": 2,
      "spacing": 4
    },
    {
      "id": "pouch",
      "type": "grid",
      "relativeTo": "pockets",
      "relativeAlign": "right",
      "relativeAlignY": "bottom",
      "fixedOffsetX": 10,
      "y": "-5%",
      "cols": 2,
      "rows": 4,
      "spacing": 4,
      "condition": "has_pouch"
    },
    {
      "id": "hotbar",
      "type": "horizontal",
      "anchor": "center",
      "x": "0%",
      "y": "15%",
      "cols": 9,
      "spacing": 4
    },
    {
      "id": "developer_panel",
      "type": "grid",
      "anchor": "top-right",
      "alignX": "right",
      "alignY": "top",
      "x": "-10px",
      "y": "10px",
      "cols": 7,
      "rows": 12,
      "spacing": 4,
      "condition": "developer_mode"
    }
  ]
}
