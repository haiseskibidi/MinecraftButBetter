{
  "id": "minecraft:player_inventory",
  "title": "container.inventory",
  "background": {
    "type": "solid",
    "color": [0.05, 0.05, 0.05, 0.8],
    "padding": 8,
    "includeGroups": ["equipment", "offhand", "pockets", "pouch"]
  },
  "groups": [
    {
      "id": "equipment",
      "type": "vertical",
      "relativeTo": "pockets",
      "relativeAlign": "left",
      "relativeAlignY": "bottom",
      "snapToGrid": true,
      "y": "-5%",
      "rows": 4,
      "spacing": 4,
      "condition": "is_armor",
      "placeholders": {
        "0": "empty_armor_slot_helmet",
        "1": "empty_armor_slot_chestplate",
        "2": "empty_armor_slot_leggings",
        "3": "empty_armor_slot_boots",
        "5": "bundle"
      }
    },
    {
      "id": "offhand",
      "type": "grid",
      "relativeTo": "pockets",
      "relativeAlign": "left",
      "relativeAlignY": "top",
      "snapToGrid": true,
      "y": "-4%",
      "cols": 1,
      "rows": 1,
      "condition": "is_offhand",
      "placeholders": {
        "0": "empty_armor_slot_shield"
      }
    },
    {
      "id": "pockets",
      "type": "grid",
      "relativeTo": "hotbar",
      "relativeAlign": "top",
      "relativeAlignX": "center",
      "fixedOffsetX": 0,
      "fixedOffsetY": "-1s",
      "centerCombined": true,
      "cols": 4,
      "rows": 2,
      "spacing": 4
    },
    {
      "id": "pouch",
      "type": "grid",
      "relativeTo": "pockets",
      "relativeAlign": "right",
      "relativeAlignY": "bottom",
      "snapToGrid": true,
      "y": "-5%",
      "cols": 2,
      "rows": 4,
      "spacing": 4,
      "condition": "has_pouch"
    },
    {
      "id": "hotbar",
      "type": "horizontal",
      "anchor": "center",
      "x": "0%",
      "y": "15%",
      "cols": 9,
      "spacing": 4,
      "background": {
        "type": "solid",
        "color": [0.05, 0.05, 0.05, 0.8],
        "padding": 6
      }
    },
    {
      "id": "developer_panel",
      "type": "grid",
      "anchor": "top-right",
      "alignX": "right",
      "alignY": "top",
      "x": "-10px",
      "y": "10px",
      "cols": 7,
      "rows": 12,
      "spacing": 4,
      "condition": "developer_mode"
    }
  ]
}
